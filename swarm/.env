# Infra
KAFKA_IMAGE=apache/kafka:4.0.2
POSTGRES_IMAGE=postgres:15
PROMETHEUS_IMAGE=prom/prometheus:latest
PROMETHEUS_URL=http://redecor_prometheus:9090
GRAFANA_IMAGE=grafana/grafana
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:v0.47.2
PROM_QUERY=

# Port
POSTGRES_PORT=5432
KAFKA_UI_PORT=8080
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Postgres
POSTGRES_USER=devops
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=extractions

# Kafka
KAFKA_BROKER=kafka:9092

# Producer
PRODUCER_METRICS_PORT=8000

# Worker
WORKER_METRICS_PORT=8001
API_TOKEN=abc123
API_TOKEN_EXPIRATION=1810000000
# Expirado
#API_TOKEN_EXPIRATION=1000

DB_HOST=postgres
